@{
    ViewBag.Title = "Order Management";
}

<div class="container mt-4">
    <h3 class="fw-bold mb-4">Order Management</h3>

    <div class="card shadow-sm p-4 mb-4">
        <h5 class="mb-3 fw-bold text-secondary">Buyer Information</h5>
        <div class="row g-3">
            <input type="hidden" id="buyerId" />
            <div class="col-md-3">
                <input type="text" id="buyerFirstName" class="form-control" placeholder="First Name" readonly>
            </div>
            <div class="col-md-3">
                <input type="text" id="buyerLastName" class="form-control" placeholder="Last Name" readonly>
            </div>
            <div class="col-md-3">
                <input type="text" id="buyerPhone" class="form-control" placeholder="Phone" readonly>
            </div>
            <div class="col-md-3">
                <button class="btn btn-outline-primary w-100" id="selectBuyerBtn" type="button">Select Buyer</button>
            </div>
        </div>

        <div id="buyerListContainer" class="mt-3 border rounded p-3 bg-light" style="display:none; max-height: 250px; overflow-y: auto;">
            <h6 class="fw-bold mb-2">Select a Customer from list:</h6>
            <table class="table table-hover table-sm mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Phone</th>
                        <th style="width: 80px;">Action</th>
                    </tr>
                </thead>
                <tbody id="buyerListTable"></tbody>
            </table>
        </div>
    </div>

    <hr class="my-4">

    <div class="card shadow-sm p-4 mb-4">
        <h5 class="mb-3 fw-bold text-secondary">Product Catalog</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Price</th>
                        <th style="width: 110px;">Quantity</th>
                        <th style="width: 100px;">Action</th>
                    </tr>
                </thead>
                <tbody id="productCatalogContainer"></tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm p-4 mb-4">
        <h5 class="mb-3 fw-bold text-secondary">Invoice Items (Basket)</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Qty</th>
                        <th style="width: 160px;">Unit Price (Editable)</th>
                        <th>Total</th>
                        <th style="width: 80px;">Action</th>
                    </tr>
                </thead>
                <tbody id="basketContainer"></tbody>
            </table>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
            <h4>Grand Total: <span id="grandTotal" class="text-success fw-bold">0</span></h4>
            <button class="btn btn-success btn-lg px-5" id="submitOrderBtn" type="button">Submit Order</button>
        </div>
    </div>
    
    <div class="card shadow-sm p-4 mt-4">
        <h5>Registered Orders</h5>
        <table class="table">
            <thead><tr><th>Date</th><th>Buyer</th><th>Total</th><th>Action</th></tr></thead>
            <tbody id="ordersListTable"></tbody>
        </table>
    </div>

</div>

<script src="~/js/order.js"></script>